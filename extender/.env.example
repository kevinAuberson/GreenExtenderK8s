# --- Carbon signal ------------------------------------------------------------
# Path to the signal JSON mounted from the carbon-signal ConfigMap.
# Override to point at a local mock file for standalone dev.
SIGNAL_FILE=/etc/carbon-signal/signal.json
SIGNAL_CACHE_TTL=5
MAX_SIGNAL_AGE=600

# --- Temporal shifting ----------------------------------------------------------
# Local-dev-only fallback thresholds (gCO2eq/kWh). Ignored once dynamic
# thresholds are available from the carbon-signal ConfigMap.
GREEN_THRESHOLD_G_PER_KWH=40
DIRTY_THRESHOLD_G_PER_KWH=70

# Max delay (hours) for flexible pods, unless overridden per-pod via
# the carbon-aware/max-delay-hours annotation.
DEFAULT_MAX_DELAY_HOURS=24

# Minimum CI gain (gCO2eq/kWh) required to justify delaying a pod.
MIN_GAIN_TO_DELAY_G_PER_KWH=5

# --- Scoring ---------------------------------------------------------------------
SCORING_W_CPU=0.7
SCORING_W_MEM=0.3

# --- Kubernetes --------------------------------------------------------------------
# Set to "true" only when running inside a Kubernetes pod.
IN_CLUSTER=false
