# --- Electricity Maps ---------------------------------------------------------
# Get your API token at https://api-portal.electricitymaps.com/
EMAPS_TOKEN=your_token_here
EMAPS_ZONE=CH

# --- Kubernetes / Prometheus --------------------------------------------------
# URL of the Prometheus server scraping Kepler metrics
PROMETHEUS_URL=http://localhost:9090

# Set to "true" only when running inside a Kubernetes pod
IN_CLUSTER=false

# --- vSphere ------------------------------------------------------------------
VCENTER_HOST=vcenter-iict.iict-heig-vd.in
VCENTER_USER=your.user@vsphere.local
VCENTER_PASSWORD=your_password